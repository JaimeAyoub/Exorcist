    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "BayerMatrix",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "uint2 pixelCoord = uint2(ScreenPos.x, ScreenPos.y);\r\nuint x = pixelCoord.x % 4;\r\nuint y = pixelCoord.y % 4;\r\nconst float bayer[16] = {\r\n     0.0/16.0,  8.0/16.0,  2.0/16.0, 10.0/16.0,\r\n    12.0/16.0,  4.0/16.0, 14.0/16.0,  6.0/16.0,\r\n     3.0/16.0, 11.0/16.0,  1.0/16.0,  9.0/16.0,\r\n    15.0/16.0,  7.0/16.0, 13.0/16.0,  5.0/16.0\r\n};\r\nOut = bayer[x + y * 4] - 0.5;"
}

